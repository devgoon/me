#     https://www.atlassian.com/git/tutorials/saving-changes/gitignore

# Node artifact files
node_modules/

# Compiled Java class files
*.class

# Compiled Python bytecode
*.py[cod]

# Log files
*.log

# Package files
*.jar

# Maven
target/

#Batch testing
output/
Inp_Imgs
dist/
build/

# JetBrains IDE
.vscode/
.vs
# JetBrains IDE
.idea/
__pycache__/

# Unit test reports
TEST*.xml

# Generated by MacOS
.DS_Store

# Generated by Windows
Thumbs.db

# Applications
*.app
*.exe
*.war


# Large media files
*.mp4
*.tiff
*.avi
*.flv
*.mov
*.wmv

# custom
changelog.txt
Readme.txt
.dccache
assets/*.txt

# secrets
.env
.env.local
.env.*.local
local.settings.json
.azurite/
azurite_storage/

db/export.sql
migrations/*.sql
