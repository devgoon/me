# Copy this file to `.env.local` and fill in real values. Keep secrets out of source control.
# Use ADO-style connection string for `DATABASE_ADO` when working with Azure SQL / sqlpackage.
# Examples below show SQL authentication (User ID + Password). If you use Integrated/AD auth
# you will need to adjust `scripts/dump-schema.sh` or provide credentials via environment vars.

# AI / API keys
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-haiku-4-5-20251001

# ADO-style connection string (preferred by scripts/run-sql-file.sh and dump-schema)
# - Wrap the entire value in quotes if it contains semicolons.
# - Example (SQL auth):
DATABASE_ADO="Data Source=your-server.database.windows.net;Initial Catalog=your_db;User ID=your_user;Password=your_password;Encrypt=True;TrustServerCertificate=False;Connect Timeout=30"

# If you prefer the URL-style connection string you may set AZURE_DATABASE_URL too (used by some libs):
# Example:
# AZURE_DATABASE_URL="sqlserver://your-server.database.windows.net:1433;database=your_db;user=your_user;password=your_password;encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30;"

# Optional overrides usable by scripts/dump-schema.sh when parsing / passing components:
# TARGET_SERVER=your-server.database.windows.net
# TARGET_DB=your_db
# SOURCE_USER=your_user    # used if you want to pass explicit credentials instead of parsing
# SOURCE_PASS=your_password

# Other local dev flags
# DEBUG_DB=1
# Anthropic API key (keep secret)
ANTHROPIC_API_KEY=sk-ant-...
# AZURE_DATABASE_URL used by Functions/SWA and general tooling (ADO-style or sqlserver:// form)
AZURE_DATABASE_URL="Data Source=lodovico.database.windows.net;Initial Catalog=lodovico;User ID=[USER];Password=[PASSWORD];Pooling=False;Connect Timeout=30;Encrypt=True;Authentication=SqlPassword;Application Name=vscode-mssql;Application Intent=ReadWrite;Command Timeout=30"
# Optional: ADO-style connection string specifically for Makefile tools like `sqlpackage`.
# If provided, `make backup-db` will use `DATABASE_ADO` directly (no conversion required).
DATABASE_ADO="Data Source=lodovico.database.windows.net;Initial Catalog=lodovico;User ID=[USER];Password=[PASSWORD];Encrypt=True;TrustServerCertificate=False;"
# Optional: AI model override
AI_MODEL=claude-haiku-4-5-20251001
