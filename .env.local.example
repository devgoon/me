# Copy this file to `.env.local` and fill in real values. Keep secrets out of source control.
# - Example (SQL auth):
# Anthropic API key (keep secret)
ANTHROPIC_API_KEY=sk-ant-...
# AZURE_DATABASE_URL used by Functions/SWA and general tooling (ADO-style or sqlserver:// form)
AZURE_DATABASE_URL="Data Source=[DBNAME].database.windows.net;Initial Catalog=lodovico;User ID=[USER];Password=[PASSWORD];Pooling=False;Connect Timeout=30;Encrypt=True;Authentication=SqlPassword;Application Name=vscode-mssql;Application Intent=ReadWrite;Command Timeout=30"
# Required for Makefile admin DB tasks like backup/restore/schema tooling.
# Use an admin-capable SQL login with sufficient permissions for export/import.
ADMIN_DATABASE_ADO="Data Source=[DBNAME].database.windows.net;Initial Catalog=lodovico;User ID=[ADMIN_USER];Password=[ADMIN_PASSWORD];Encrypt=True;TrustServerCertificate=False;"
# Optional: AI model override
AI_MODEL=claude-haiku-4-5-20251001
# Azure WebJobsStorage connection string for local development (Functions emulator)
AzureWebJobsStorage=UseDevelopmentStorage=true
