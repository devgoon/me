# Copy this file to .env.local and fill in the secret values (DO NOT commit .env.local)

# Runtime selection for Azure Functions
FUNCTIONS_WORKER_RUNTIME=node

# Storage used by Functions (Azurite local emulator or real storage connection string)
AzureWebJobsStorage=UseDevelopmentStorage=true

# Anthropic API key (keep secret)
ANTHROPIC_API_KEY=sk-ant-...

# Database connection for local development (preferred for Makefile)
# Use `DATABASE_URL` for the Functions/SWA/Make tooling. Provide either an ADO-style connection string
# (Data Source=...;Initial Catalog=...;User ID=...;Password=...;) or a sqlserver://...;key=val;... form.
# DATABASE_URL used by Functions/SWA and general tooling (ADO-style or sqlserver:// form)
DATABASE_URL="Data Source=lodovico.database.windows.net;Initial Catalog=lodovico;User ID=[USER];Password=[PASSWORD];Pooling=False;Connect Timeout=30;Encrypt=True;Authentication=SqlPassword;Application Name=vscode-mssql;Application Intent=ReadWrite;Command Timeout=30"
# Optional: ADO-style connection string specifically for Makefile tools like `sqlpackage`.
# If provided, `make backup-db` will use `DATABASE_ADO` directly (no conversion required).
DATABASE_ADO="Data Source=lodovico.database.windows.net;Initial Catalog=lodovico;User ID=[USER];Password=[PASSWORD];Encrypt=True;TrustServerCertificate=False;"

AZURE_SQL_SERVER=lodovico.database.windows.net
AZURE_SQL_DATABASE=lodovico
AZURE_SQL_USER=[USER]
AZURE_SQL_PASSWORD=[PASSWORD]
AZURE_SQL_PORT=1433
AZURE_SQL_AUTHENTICATIONTYPE=SqlPassword

# Optional: AI model override
AI_MODEL=claude-sonnet-4-20250514
