{
  "all": false,
  "include": [
    "js/**/*.js"
  ],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.js",
    "node_modules/**",
    "vendor/**"
  ],
  "reporter": ["lcov", "text", "text-summary"],
  "report-dir": "coverage",
  "temp-directory": ".nyc_output",
  "check-coverage": true,
  "lines": 80
}
