{
  "name": "me",
  "version": "1.0.0",
  "description": "Personal website for Lodovico Minnocci",
  "main": "frontend/index.html",
  "author": "Lodovico Minnocci",
  "license": "MIT",
  "scripts": {
    "test": "npx jest --runInBand --testPathPattern=tests/",
    "build": "echo 'No UI build required'",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html}\"",
    "coverage": "jest --coverage --coverageReporters=text --coverageReporters=text-summary --runInBand",
    "coverage:api": "cd api && npm run coverage",
    "coverage:assets": "cd frontend/assets && npm run coverage || true",
    "lint": "npx eslint@8 \"api/**/*.js\" \"frontend/assets/js/**/*.js\" --ext .js --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.js\"",
    "lint:fix": "npx eslint@8 \"api/**/*.js\" \"frontend/assets/js/**/*.js\" --ext .js --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.js\" --fix"
  },
  "devDependencies": {
    "azurite": "^3.12.0",
    "cspell": "latest",
    "eslint": "10.1.0",
    "prettier": "^2.8.8",
    "jest": "^29.6.0",
    "nyc": "^15.1.0",
    "jest-environment-jsdom": "^30.3.0",
    "linkinator": "latest"
  },
  "jest": {
    "testMatch": [
      "<rootDir>/tests/**/*.test.js"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "api/**/*.js",
      "frontend/assets/js/**/*.js"
    ],
    "coverageDirectory": "coverage"
  },
  "engines": {
    "node": "22.x"
  }
}
