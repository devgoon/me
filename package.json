{
  "name": "me",
  "version": "1.0.0",
  "description": "Personal website for Lodovico Minnocci",
  "main": "index.html",
  "author": "Lodovico Minnocci",
  "license": "MIT",
  "scripts": {
    "build:ts": "tsc --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "migrate": "node-pg-migrate -d $DATABASE_URL -m migrations",
    "migrate:up": "node-pg-migrate up -d $DATABASE_URL -m migrations",
    "migrate:down": "node-pg-migrate down -d $DATABASE_URL -m migrations"
  },
  "devDependencies": {
    "cspell": "latest",
    "http-server": "latest",
    "linkinator": "latest",
    "node-pg-migrate": "^8.0.4",
    "pa11y": "latest",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
