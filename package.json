{
  "name": "me",
  "version": "2.0.0",
  "description": "Personal website for Lodovico Minnocci",
  "main": "index.html",
  "author": "Lodovico Minnocci",
  "license": "MIT",
  "scripts": {
    "lint": "npx eslint src/ui src/api --ext .ts,.tsx",
    "build:ui": "tsc --project tsconfig.json",
    "build:api": "tsc --project tsconfig.api.json && npx copyfiles -u 2 src/api/host.json src/api/local.settings.json src/api/**/function.json api/",
    "build": "npm run build:ui && npm run build:api",
    "clean": "rm -f assets/js/*.js && rm -rf .azurite || true",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "migrate": "node-pg-migrate -d $DATABASE_URL -m migrations",
    "migrate:up": "node-pg-migrate up -d $DATABASE_URL -m migrations",
    "migrate:down": "node-pg-migrate down -d $DATABASE_URL -m migrations"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "copyfiles": "^2.4.1",
    "cspell": "latest",
    "eslint": "^10.0.3",
    "eslint-plugin-jsdoc": "^62.8.0",
    "http-server": "latest",
    "linkinator": "latest",
    "node-pg-migrate": "^8.0.4",
    "pa11y": "^9.1.1",
    "tscp": "^1.0.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
