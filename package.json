{
  "name": "me",
  "version": "1.0.0",
  "description": "Personal website for Lodovico Minnocci",
  "main": "frontend-react/index.html",
  "author": "Lodovico Minnocci",
  "license": "MIT",
  "scripts": {
    "test": "npm run test:api",
    "test:api": "npm --prefix api run test:vitest",
    "test:evals": "node scripts/run-evals.js",
    "evals:export:chat-cache": "node scripts/export-chat-cache-evals.js",
    "build": "echo 'No UI build required'",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "format:check": "prettier --check \"**/*.{js,json,md,css,html}\"",
    "update-default-data": "node scripts/update-default-data.js",
    "lint": "npx eslint \"api/**/*.js\" \"frontend-react/src/**/*.{js,jsx}\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.*\"",
    "lint:fix": "npx eslint \"api/**/*.js\" \"frontend-react/src/**/*.{js,jsx}\" --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.*\" --fix",
    "react:dev": "npm --prefix frontend-react run dev",
    "react:build": "npm --prefix frontend-react run build",
    "react:build:watch": "npm --prefix frontend-react run build:watch",
    "react:preview": "npm --prefix frontend-react run preview",
    "test:ui": "./frontend-react/node_modules/.bin/vitest run --config ./vite.config.ui.js --root . --coverage",
    "test:e2e": "npx playwright test --config=playwright.config.js --project=chromium --reporter=list,html"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "jsdom": "^29.1.0",
    "prettier": "^2.8.8",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "22.x"
  }
}
