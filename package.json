{
  "name": "me",
  "version": "1.0.0",
  "description": "Personal website for Lodovico Minnocci",
  "main": "index.html",
  "author": "Lodovico Minnocci",
  "license": "MIT",
  "scripts": {
    "clean": "rm -f assets/js/*.js && rm -rf .azurite || true",
    "migrate": "node-pg-migrate -d $DATABASE_URL -m migrations",
    "migrate:up": "node-pg-migrate up -d $DATABASE_URL -m migrations",
    "migrate:down": "node-pg-migrate down -d $DATABASE_URL -m migrations",
    "test": "jest --runInBand",
    "lint": "npx eslint@8 \"api/**/*.js\" \"assets/js/**/*.js\" --ext .js --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.js\"",
    "lint:fix": "npx eslint@8 \"api/**/*.js\" \"assets/js/**/*.js\" --ext .js --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.js\" --fix"
  },
  "devDependencies": {
    "cspell": "latest",
    "http-server": "latest",
    "linkinator": "latest",
    "node-pg-migrate": "^8.0.4",
    "jest-environment-jsdom": "^29.6.0",
    "pa11y": "latest",
    "jest": "^29.6.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
